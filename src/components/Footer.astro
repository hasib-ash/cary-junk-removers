---
const serviceAreas = [
  'Cary', 'Apex', 'Morrisville', 'Holly Springs',
  'Fuquay-Varina', 'Raleigh', 'Durham', 'Chapel Hill',
];

const services = [
  { label: 'Household Junk Removal', href: '/services/household-junk-removal' },
  { label: 'Furniture Removal', href: '/services/furniture-removal' },
  { label: 'Appliance Removal', href: '/services/appliance-removal' },
  { label: 'Hot Tub Removal', href: '/services/hot-tub-removal' },
  { label: 'Shed Removal', href: '/services/shed-removal' },
  { label: 'Construction Debris', href: '/services/construction-debris' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Services', href: '#services' },
  { label: 'Projects', href: '#projects' },
  { label: 'Blog', href: '/blog' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Contact', href: '#contact' },
];

const year = new Date().getFullYear();
---

<footer id="service-areas" class="bg-slate-900 text-slate-400">

  <!-- Top Section -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <span class="text-2xl font-black text-white">Cary<span class="text-orange-500">Junk</span>Removers</span>
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-xs">
          Professional, affordable junk removal serving Cary and the greater Triangle area. Licensed, insured, and 5-star rated.
        </p>
        <!-- Social Links -->
        <div class="flex gap-3">
          {[
            { label: 'Facebook', path: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
            { label: 'Google', path: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z' },
            { label: 'Yelp', path: 'M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18c-4.418 0-8-3.582-8-8s3.582-8 8-8 8 3.582 8 8-3.582 8-8 8z' },
          ].map(s => (
            <a href="#" aria-label={s.label} class="w-9 h-9 rounded-lg bg-white/5 hover:bg-orange-500 flex items-center justify-center transition-colors duration-200">
              <svg class="w-4 h-4 text-slate-400 hover:text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={s.path}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-bold mb-5 text-sm uppercase tracking-wider">Services</h3>
        <ul class="space-y-3">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-sm hover:text-orange-400 transition-colors duration-200">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-bold mb-5 text-sm uppercase tracking-wider">Company</h3>
        <ul class="space-y-3">
          {company.map(c => (
            <li>
              <a href={c.href} class="text-sm hover:text-orange-400 transition-colors duration-200">{c.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact + Service Areas -->
      <div>
        <h3 class="text-white font-bold mb-5 text-sm uppercase tracking-wider">Contact</h3>
        <ul class="space-y-3 mb-8">
          <li>
            <a href="tel:+19195550000" class="flex items-center gap-2 text-sm hover:text-orange-400 transition-colors duration-200">
              <svg class="w-4 h-4 shrink-0 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
              (919) 555-0000
            </a>
          </li>
          <li>
            <a href="mailto:info@caryjunkremovers.com" class="flex items-center gap-2 text-sm hover:text-orange-400 transition-colors duration-200">
              <svg class="w-4 h-4 shrink-0 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              info@caryjunkremovers.com
            </a>
          </li>
          <li class="flex items-start gap-2 text-sm">
            <svg class="w-4 h-4 shrink-0 text-orange-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Cary, NC & Surrounding Areas
          </li>
          <li class="flex items-start gap-2 text-sm">
            <svg class="w-4 h-4 shrink-0 text-orange-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Mon – Sat: 7am – 7pm<br/>Sun: 8am – 5pm
          </li>
        </ul>

        <h3 class="text-white font-bold mb-3 text-sm uppercase tracking-wider">Service Areas</h3>
        <div class="flex flex-wrap gap-1.5">
          {serviceAreas.map(area => (
            <span class="text-xs bg-white/5 border border-white/10 text-slate-400 px-2.5 py-1 rounded-full">{area}</span>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-sm text-slate-500">
        © {year} Cary Junk Removers. All rights reserved.
      </p>
      <div class="flex gap-5 text-sm">
        <a href="/privacy-policy" class="text-slate-500 hover:text-orange-400 transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-slate-500 hover:text-orange-400 transition-colors">Terms of Service</a>
        <a href="/sitemap-index.xml" class="text-slate-500 hover:text-orange-400 transition-colors">Sitemap</a>
      </div>
    </div>
  </div>

</footer>

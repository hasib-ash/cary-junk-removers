---
const phone = '(919) 555-0000';
const phoneHref = 'tel:+19195550000';

const benefits = [
  'Same-Day Service Available',
  'Free, No-Obligation Estimates',
  'We Do All The Heavy Lifting',
  'Eco-Friendly Disposal',
];

const trust = [
  { label: 'Licensed & Insured' },
  { label: 'Locally Owned & Operated' },
  { label: '500+ Jobs Completed' },
  { label: '5-Star Rated' },
];
---

<section class="bg-slate-900 relative overflow-hidden">
  <!-- Subtle background grid -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
  <!-- Orange glow -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-orange-500 opacity-5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/4"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Content -->
      <div>
        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2 bg-orange-500/10 border border-orange-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg class="w-3.5 h-3.5 text-orange-400 fill-orange-400" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}
          </span>
          <span class="text-orange-400 text-xs font-semibold uppercase tracking-wider">Cary's Top-Rated Junk Removal</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-5">
          Clear The Clutter.<br/>
          <span class="text-orange-500">Reclaim Your Space.</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-slate-300 leading-relaxed mb-8 max-w-xl">
          Professional junk removal in Cary, NC. We handle everything — from single items to full estate cleanouts — quickly, affordably, and with zero hassle on your end.
        </p>

        <!-- Bullet Benefits -->
        <ul class="space-y-3 mb-10">
          {benefits.map(b => (
            <li class="flex items-center gap-3 text-slate-200">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-orange-500 flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="font-medium">{b}</span>
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a
            href="#contact"
            class="inline-flex items-center justify-center bg-orange-500 hover:bg-orange-600 text-white font-bold text-lg px-8 py-4 rounded-xl transition-all duration-200 shadow-lg hover:shadow-orange-500/30 hover:-translate-y-0.5"
          >
            Get Free Estimate
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href={phoneHref}
            class="inline-flex items-center justify-center border-2 border-white/20 hover:border-white/50 text-white font-bold text-lg px-8 py-4 rounded-xl transition-all duration-200"
          >
            <svg class="w-5 h-5 mr-2 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            {phone}
          </a>
        </div>

        <!-- Trust Bar -->
        <div class="flex flex-wrap gap-x-6 gap-y-3 pt-8 border-t border-white/10">
          {trust.map(t => (
            <div class="flex items-center gap-2 text-slate-400 text-sm">
              <svg class="w-4 h-4 text-green-400 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span>{t.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Hero Visual -->
      <div class="relative hidden lg:block">
        <!-- Main image placeholder -->
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] border border-white/10">
          <img src="/images/hero-crew.jpg" alt="Cary Junk Removers crew with truck ready to work" class="w-full h-full object-cover" />
        </div>

        <!-- Floating Stats Card -->
        <div class="absolute -bottom-5 -left-5 bg-white rounded-2xl shadow-2xl p-5 flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-orange-100 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl font-black text-slate-900">500+</p>
            <p class="text-slate-500 text-sm font-medium">Jobs Completed</p>
          </div>
        </div>

        <!-- Floating Same-Day Badge -->
        <div class="absolute -top-4 -right-4 bg-orange-500 text-white rounded-xl px-4 py-2.5 shadow-lg">
          <p class="text-xs font-bold uppercase tracking-wider">Same-Day</p>
          <p class="text-xs font-semibold opacity-90">Available</p>
        </div>
      </div>

    </div>
  </div>
</section>

---
const reasons = [
  {
    title: 'Same-Day Availability',
    desc: 'Most jobs can be scheduled same day or next day. We work around your timeline, not the other way around.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: 'Upfront Pricing',
    desc: 'We give you a firm price before we start. No hidden fees, no surprise charges when the job is done.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: 'Professional Crew',
    desc: 'Every member of our team is trained, uniformed, and background-checked. We treat your home with respect.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    title: 'Licensed & Insured',
    desc: 'Fully licensed and insured in North Carolina. Your property and belongings are protected on every job.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Eco-Friendly Disposal',
    desc: 'We donate usable items to local charities and recycle materials whenever possible. Less to landfill.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>`,
  },
  {
    title: '5-Star Customer Service',
    desc: 'Over 200 five-star reviews on Google and Yelp. Our reputation is our best advertisement.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>`,
  },
];
---

<section class="bg-slate-900 py-20 md:py-28 relative overflow-hidden">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, #f97316 1px, transparent 1px); background-size: 48px 48px;"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-orange-500 font-semibold uppercase tracking-wider text-sm mb-3">Our Difference</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-4">
        Why Homeowners Choose Us
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        We've built our business on one thing: making junk removal the easiest experience you'll have with any home service company.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {reasons.map(r => (
        <div class="group bg-white/5 hover:bg-white/10 border border-white/10 hover:border-orange-500/30 rounded-2xl p-6 lg:p-7 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-5 group-hover:bg-orange-500/20 transition-colors duration-300">
            <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={r.icon} />
          </div>
          <h3 class="text-white font-bold text-lg mb-2">{r.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{r.desc}</p>
        </div>
      ))}
    </div>

    <!-- Trust badges row -->
    <div class="mt-14 pt-10 border-t border-white/10 flex flex-wrap justify-center items-center gap-8 lg:gap-12">
      {[
        { stat: '500+', label: 'Jobs Completed' },
        { stat: '4.9★', label: 'Average Rating' },
        { stat: '200+', label: 'Google Reviews' },
        { stat: '3+', label: 'Years Serving Cary' },
      ].map(b => (
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-black text-orange-500">{b.stat}</p>
          <p class="text-slate-400 text-sm font-medium mt-1">{b.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>

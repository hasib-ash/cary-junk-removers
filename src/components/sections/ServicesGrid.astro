---
const services = [
  {
    slug: 'household-junk-removal',
    image: '/images/Residential.jpg',
    title: 'Household Junk Removal',
    desc: 'Clear out old furniture, electronics, clothing, and general clutter from any room in your home.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    slug: 'furniture-removal',
    image: '/images/Cleanouts.jpg',
    title: 'Furniture Removal',
    desc: 'Sofas, mattresses, desks, dressers, and bed frames removed safely — no scrapes, no damage.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
  },
  {
    slug: 'appliance-removal',
    image: '/images/truck-full.webp',
    title: 'Appliance Removal',
    desc: 'Washers, dryers, refrigerators, microwaves, and ovens removed and responsibly recycled.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    slug: 'vehicle-removal',
    image: '/images/Car.jpg',
    title: 'Junk Car & Vehicle Removal',
    desc: 'Old cars, trucks, and scrap vehicles hauled away fast. We handle the heavy equipment so you don\'t have to.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/>`,
  },
  {
    slug: 'yard-debris-removal',
    image: '/images/yard-waste.jpg',
    title: 'Yard Debris & Shed Removal',
    desc: 'Storm cleanup, brush piles, old sheds, and yard waste hauled away. We handle the outdoor mess too.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
  },
  {
    slug: 'construction-debris',
    image: '/images/construction-debris.jpg',
    title: 'Construction Debris Removal',
    desc: 'Post-renovation cleanup of drywall, lumber, tile, flooring, and any other construction waste.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
];
---

<section id="services" class="bg-slate-50 py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-orange-500 font-semibold uppercase tracking-wider text-sm mb-3">What We Remove</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-slate-900 mb-4">
        Full-Service Junk Removal
      </h2>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        From single items to full property cleanouts, we handle it all. If you can point to it, we can remove it.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map(service => (
        <div class="group bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-orange-200 hover:shadow-xl transition-all duration-300">
          <!-- Service Image -->
          <div class="aspect-video overflow-hidden">
            <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>

          <!-- Content -->
          <div class="p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{service.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-5">{service.desc}</p>
            <a
              href={`/services/${service.slug}`}
              class="inline-flex items-center gap-1.5 text-orange-500 hover:text-orange-600 font-semibold text-sm transition-colors group/link"
            >
              Learn More
              <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <p class="text-slate-500 mb-4">Don't see your item? We probably take it.</p>
      <a href="tel:+19195550000" class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-bold px-7 py-3.5 rounded-xl transition-colors duration-200">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        Call (919) 555-0000 To Ask
      </a>
    </div>

  </div>
</section>
